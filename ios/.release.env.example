# iOS release yapilandirmasi. Bu dosyayi `ios/.release.env` olarak kopyalayip
# kendi degerlerinle doldur. Gercek dosya gitignore'dadir; ASLA repoya eklenmez.
#
# Bu degerleri ortam degiskeni olarak da verebilirsin; o zaman bu dosya gerekmez.

# App Store Connect API anahtarinin Issuer ID'si (UUID).
# App Store Connect > Users and Access > Integrations (Keys) > ust kisimda "Issuer ID".
APP_STORE_ISSUER_ID=00000000-0000-0000-0000-000000000000

# API anahtarinin Key ID'si. Dosya adindan: AuthKey_<KEY_ID>.p8
# .p8 dosyasi ~/.appstoreconnect/private_keys/ icinde olmali.
APP_STORE_KEY_ID=0000000000
