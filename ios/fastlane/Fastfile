default_platform(:ios)

platform :ios do
  # App Store dagitim profili (manuel imza). Apple portalindaki profil adiyla
  # birebir ayni olmali.
  APPSTORE_PROFILE_NAME = "com.ekrembulbul.ezanvakti AppStore"
  APP_BUNDLE_ID = "com.ekrembulbul.ezanvakti"

  desc "IPA derle ve TestFlight'a yukle (manuel imza)"
  lane :beta do
    # App Store Connect API anahtari yalnizca YUKLEME icin kullanilir; imza/profil
    # uretimi yapilmaz (manuel imza). Boylece sertifika kotasi hic zorlanmaz.
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_P8_BASE64"],
      is_key_content_base64: true,
    )

    # CI icin gecici keychain olustur
    setup_ci

    # Dagitim sertifikasini gecici keychain'e aktar (ozel anahtar dahil)
    import_certificate(
      certificate_path: ENV["CERT_PATH"],
      certificate_password: ENV["CERT_PASSWORD"],
      keychain_name: "fastlane_tmp_keychain",
      keychain_password: "",
    )

    # Manuel imzayi YALNIZCA Runner uygulamasina uygula. Global xcargs verilirse
    # profil tum Pod (framework) hedeflerine de dayatilir ve "does not support
    # provisioning profiles" hatasi alinir; framework'ler profil kabul etmez.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: ENV["APPLE_TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      bundle_identifier: APP_BUNDLE_ID,
      profile_name: APPSTORE_PROFILE_NAME,
      targets: ["Runner"],
    )

    # xcodebuild yalnizca verilen sertifika + profili kullanir; App Store Connect'e
    # gidip sertifika/profil URETMEZ. -allowProvisioningUpdates bilerek kaldirildi.
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      # IPA adi bosluksuz olsun; CFBundleName 'Ezan Vakti' bosluklu IPA uretiyor ve
      # yeni altool (Xcode 26.3 / fastlane 2.236) bosluklu yolu acamiyordu (hata 259).
      output_name: "ezanvakti",
      export_options: {
        teamID: ENV["APPLE_TEAM_ID"],
        signingStyle: "manual",
        provisioningProfiles: {
          APP_BUNDLE_ID => APPSTORE_PROFILE_NAME,
        },
      },
    )

    # TestFlight'a yukle (islenmeyi bekleme)
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end
end
